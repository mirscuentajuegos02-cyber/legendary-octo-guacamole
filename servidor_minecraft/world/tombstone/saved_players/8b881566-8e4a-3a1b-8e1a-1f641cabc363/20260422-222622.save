rotection:0},"voltaic:radiationrecipient":{prevrecieved:0.0d,prevrecievedstrength:0.0d,recieved:0.0d,recievedstrength:0.0d}},ForgeData:{Backward:1b,CanAttack:0.0d,CanUseRoar:1b,Forward:0b,LeftClicked:0b,LeftHold:0.0d,LeftPressed:0b,PlayerPersisted:{BalmData:{WaystonesData:{Waystones:["5f9f48ca-8938-4036-a869-768383c6bb94","58373e5a-8697-4bec-a384-47d415bdd35a","18b4c4fc-8e4c-4a76-985d-895aae58b1f5"]}},prehistoricfauna_has_ancient_journal:1b,tb_cooldowns:[],tb_grave_locations:[],tb_last_ground_location_dim:"minecraft:overworld",tb_last_ground_location_x:1378,tb_last_ground_location_y:66,tb_last_ground_location_z:827,tb_stored_cooldown:[I;0,0,0,0]},RightClicked:0b,RightHold:0.0d,RightPressed:0b,RisingPressed:0b,Slot:42.0d,StealRate:3.8919527976329d,VehicleRun:0b},Health:13.434999f,HurtByTimestamp:12132,HurtTime:0s,Inventory:[{Count:1b,ForgeCaps:{"monsterexpansion:weapon_data":{}},Slot:0b,id:"minecraft:stone_sword",tag:{Damage:57}},{Count:1b,Slot:1b,id:"minecraft:diamond_pickaxe",tag:{Damage:104}},{Count:1b,ForgeCaps:{"monsterexpansion:weapon_data":{}},Slot:2b,id:"minecraft:stone_axe",tag:{Damage:119}},{Count:32b,Slot:3b,id:"minecraft:apple"},{Count:1b,Slot:4b,id:"minecraft:dirt"},{Count:32b,Slot:5b,id:"minecraft:white_wool"},{Count:12b,Slot:6b,id:"minecraft:redstone"},{Count:22b,Slot:7b,id:"minecraft:light_gray_wool"},{Count:6b,Slot:8b,id:"minecraft:red_wool"},{Count:1b,Slot:9b,id:"waystones:waystone"},{Count:1b,Slot:10b,id:"minecraft:cauldron"},{Count:1b,Slot:11b,id:"minecraft:writable_book",tag:{pages:["We made it to the campsite around noon, and honestly, the place looks perfect. Tall trees, fresh air, and that quiet kind of peace you only get this far from town. Me, Leon and Yannick set up our tents pretty quickly, then just chilled around the fire pit.","But... something feels weird about this forest. I can’t explain it, but the atmosphere shifts when the sun sets. The trees seem taller, like they’re leaning in closer. And all of us swear we saw lights flickering between the trees. Probably just other hikers, right? ","Still, they move... fast. Too fast to be people just walking around with flashlights.

I camped here a few years ago, and I don’t remember anything like this. Although, I do remember something else... ","One evening, I spotted a group of people dressed in black hanging around some old stone structure. I only saw them through my spyglass and I figured it was just some weird outdoor club or whatever. Didn’t think much of it.","Anyway, Leon went to pee like twenty minutes ago, and he hasn’t come back. We keep calling his name, but all we hear are weird noises from the bushes. If this is a prank, I swear I’m gonna kill him when he gets back. But it’s starting to freak me out.","We’ve got five days out here. We planned hikes, swimming, and just escaping life for a bit. But now, I feel this knot in my stomach. Every time I look into the forest, I think I see shapes moving. And the lights, they’re still out there, darting around the trees.","Maybe we’re just imagining things...

 

        Or maybe... 


something's 

           watching us."]}},{Count:1b,Slot:12b,id:"creepingwoods:camera"},{Count:4b,Slot:13b,id:"minecraft:item_frame"},{Count:1b,Slot:14b,id:"creepingwoods:flashlight_off"},{Count:1b,Slot:15b,id:"minecraft:white_bed"},{Count:1b,Slot:16b,id:"minecraft:coarse_dirt"},{Count:1b,Slot:17b,id:"minecraft:wheat_seeds"},{Count:1b,ForgeCaps:{"monsterexpansion:weapon_data":{}},Slot:18b,id:"minecraft:iron_axe",tag:{Damage:0}},{Count:1b,Slot:19b,id:"minecraft:skeleton_skull"},{Count:1b,Slot:20b,id:"creepingwoods:old_radio"},{Count:1b,Slot:21b,id:"minecraft:lantern"},{Count:40b,Slot:22b,id:"minecraft:oak_log"},{Count:13b,Slot:23b,id:"minecraft:oak_sapling"},{Count:5b,Slot:24b,id:"minecraft:birch_sapling"},{Count:17b,Slot:25b,id:"minecraft:birch_log"},{Count:11b,Slot:26b,id:"minecraft:stick"},{Count:5b,Slot:27b,id:"unusualprehistory:tar_fossil_item"},{Count:1b,Slot:28b,id:"minecraft:stone_pickaxe",tag:{Damage:103}},{Count:1b,Slot:29b,id:"minecraft:bone"},{Count:2b,Slot:30b,id:"minecraft:mutton"},{Count:1b,Slot:100b,id:"kawaiidishes:brown_shoes",tag:{}},{Count:1b,Slot:101b,id:"kawaiidishes:bunny_suit_socks",tag:{}},{Count:1b,Slot:102b,id:"iceandfire:armor_copper_metal_chestplate",tag:{Damage:62}},{Count:1b,Slot:103b,id:"iceandfire:armor_copper_metal_helmet",tag:{Damage:62}},{Count:1b,Slot:-106b,id:"minecraft:shield",tag:{Damage:239}}],Invulnerable:0b,LastDeathLocation:{dimension:"minecraft:overworld",pos:[I;1177,62,300]},LeashedByEntities:[],LeashingEntities:[],Motion:[0.0d,0.0d,0.0d],OnGround:0b,PortalCooldown:0,Pos:[1070.643285534892d,69.19999980926514d,291.90046067353444d],RootVehicle:{Attach:[I;-421391643,-1239268252,-1335620441,914371968],Entity:{AbsorptionAmount:0.0f,Air:300s,ArmorDropChances:[0.085f,0.085f,0.085f,0.085f],ArmorItems:[{},{},{},{}],Attributes:[{Base:0.08d,Name:"forge:entity_gravity"},{Base:0.35d,Name:"minecraft:generic.movement_speed"},{Base:15.0d,Name:"minecraft:generic.attack_damage"},{Base:150.0d,Name:"minecraft:generic.max_health"},{Base:32.0d,Modifiers:[{A